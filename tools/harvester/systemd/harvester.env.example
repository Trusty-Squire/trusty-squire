# Operator env-file template for the harvester systemd units.
# Copy to ~/.config/trusty-squire/harvester.env and edit, then
# chmod 0600 (this file contains secrets).
#
#     mkdir -p ~/.config/trusty-squire
#     cp tools/harvester/systemd/harvester.env.example \
#        ~/.config/trusty-squire/harvester.env
#     chmod 0600 ~/.config/trusty-squire/harvester.env
#
# systemd loads this via `EnvironmentFile=-%h/.config/trusty-squire/
# harvester.env` (the leading `-` makes the file optional — units
# fall through to in-process defaults if it's absent).

# ── Telegram (daily digest + crash alerts) ────────────────────────
# Get this from @BotFather. After setting, send /start to your bot
# from your Telegram account so daily-digest.mjs can auto-resolve
# the chat_id on first run.
# TELEGRAM_BOT_TOKEN=

# ── Residential proxy (optional) ──────────────────────────────────
# When set, the universal bot routes egress through this SOCKS proxy
# for datacenter-class ASNs. Mac/Tailscale tunnel pattern:
#   ssh -fN -D 127.0.0.1:1080 dani@macbook-pro-7
# Leave UNIVERSAL_BOT_PROXY_URL unset (or empty) AND set
# UNIVERSAL_BOT_PROXY_ALWAYS=false for direct-egress runs.
# UNIVERSAL_BOT_PROXY_URL=socks5://127.0.0.1:1080
# UNIVERSAL_BOT_PROXY_ALWAYS=true

# ── Budget cap ────────────────────────────────────────────────────
# Daily LLM-spend cap in USD (default $5). Halts globally when
# exceeded; resets at UTC midnight.
# HARVESTER_DAILY_BUDGET_USD=5

# ── MCP version pin (optional) ────────────────────────────────────
# Default is `@next` (= latest staging rc). Pin to a specific rc for
# forensic re-runs against a known version.
# HARVESTER_MCP_VERSION=0.6.14-rc.33

# ── GitHub repo ───────────────────────────────────────────────────
# Where per-service issues + halt issues are filed.
GH_REPO=Trusty-Squire/trusty-squire

# ── Chrome profile (optional) ─────────────────────────────────────
# Default is ~/.trusty-squire/chrome-profile (the same profile the
# mcp `connect --provider=github` flow seeds). Override only if you
# want the harvester on a separate identity.
# TRUSTY_SQUIRE_PROFILE_DIR=/home/lunchbox/.trusty-squire/chrome-profile
