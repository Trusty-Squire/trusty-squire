{
  "name": "@trusty-squire/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "Local MCP server vibe coding agents install. Thin relay to the Trusty Squire API.",
  "main": "./dist/server.js",
  "bin": {
    "squire-mcp": "./dist/install/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "dev:server": "tsx src/server.ts",
    "install:dev": "tsx src/install/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@trusty-squire/universal-bot": "workspace:*",
    "open": "^10.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
