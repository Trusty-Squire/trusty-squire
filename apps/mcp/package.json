{
  "name": "@trusty-squire/mcp",
  "version": "0.9.19-rc.23",
  "mcpName": "io.github.Trusty-Squire/mcp",
  "type": "module",
  "description": "Local MCP server vibe coding agents install. Thin relay to the Trusty Squire API, with the bundled universal signup bot.",
  "main": "./dist/server.js",
  "bin": {
    "mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "assets",
    "!dist/bot/eval-*",
    "!dist/bot/build-corpus.*",
    "!dist/bot/label-target.*",
    "!dist/bot/failure-stats.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trusty-Squire/trusty-squire.git",
    "directory": "apps/mcp"
  },
  "homepage": "https://github.com/Trusty-Squire/trusty-squire#readme",
  "bugs": {
    "url": "https://github.com/Trusty-Squire/trusty-squire/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "dev:server": "tsx src/bin.ts server",
    "install:dev": "tsx src/bin.ts install",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@clack/prompts": "^0.11.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@trusty-squire/skill-schema": "workspace:*",
    "boxen": "^8.0.1",
    "canonicalize": "^2.0.0",
    "chalk": "^5.3.0",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "patchright": "^1.60.2",
    "playwright": "^1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rebrowser-playwright-core": "^1.52.0",
    "smol-toml": "^1.6.1",
    "tldts": "^7.0.30",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@trusty-squire/inbox": "workspace:*",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
