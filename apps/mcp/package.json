{
  "name": "@trusty-squire/mcp",
  "version": "1.0.49",
  "license": "MIT",
  "mcpName": "ai.trustysquire/trusty-squire",
  "type": "module",
  "description": "Trusty Squire signs up / in to websites for you so you don’t have to.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "coding-agent",
    "browser-automation",
    "website-signup",
    "website-login",
    "saas",
    "api-keys",
    "secrets-management",
    "claude-code",
    "cursor",
    "codex",
    "opencode"
  ],
  "main": "./dist/server.js",
  "bin": {
    "mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trusty-Squire/trusty-squire.git",
    "directory": "apps/mcp"
  },
  "homepage": "https://trustysquire.ai",
  "bugs": {
    "url": "https://github.com/Trusty-Squire/trusty-squire/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "smoke:opencode": "node scripts/smoke-opencode.mjs",
    "dev:server": "tsx src/bin.ts server",
    "install:dev": "tsx src/bin.ts install",
    "prepack": "node scripts/package-readme.mjs stage",
    "postpack": "node scripts/package-readme.mjs clean",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@clack/prompts": "^0.11.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@trusty-squire/skill-schema": "workspace:*",
    "boxen": "^8.0.1",
    "canonicalize": "^2.0.0",
    "chalk": "^5.3.0",
    "jsonc-parser": "^3.3.1",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "patchright": "^1.60.2",
    "playwright": "^1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rebrowser-playwright-core": "^1.52.0",
    "smol-toml": "^1.6.1",
    "tldts": "^7.0.30",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
