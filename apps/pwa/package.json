{
  "name": "@trusty-squire/pwa",
  "version": "0.1.0",
  "private": true,
  "description": "Trusty Squire user-facing PWA. Account signup, mandate signing, MCP install, dashboard, ledger.",
  "scripts": {
    "build": "next build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "dev": "next dev -p 3002",
    "start": "next start -p 3002",
    "lint": "next lint",
    "rasterize-icons": "tsx scripts/rasterize-icons.ts"
  },
  "dependencies": {
    "@vouchflow/web": "0.2.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.0.0-beta.6",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "happy-dom": "^15.0.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0-beta.6",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
