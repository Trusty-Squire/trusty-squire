// Auth & operational persistence for Trusty Squire API.
//
// Separate from packages/inbox/prisma/schema.prisma because inbox has
// its own retention policy (body 7d, metadata 90d). Auth data stays
// indefinitely until explicitly revoked.
//
// This schema gets its own database — `trustysquire` on the
// trusty-squire-db cluster (AUTH_DATABASE_URL). It cannot share a
// database with the inbox schema: `prisma db push` reconciles a
// database to exactly one schema and drops everything else.

generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/api-client"
  // `native` for local dev; the openssl-3.0.x musl target for the
  // node:alpine deploy image (Alpine ships OpenSSL 3, not 1.1).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}

// Tier 0 machine tokens for anonymous MCP installs.
// One row per `npx @trusty-squire/mcp install`.
//
// The asn_* columns capture the network class of the install machine
// (ipinfo lookup at /v1/install time) so we can correlate captcha
// failure rates with egress reputation. They're nullable because
// the lookup is best-effort — older tokens issued before the column
// existed, and tokens issued during an ipinfo outage, both stay null.
model MachineToken {
  token             String    @id
  created_at        DateTime  @default(now())
  // Vestigial: the free-signup quota was removed (provisioning is free
  // during beta), so nothing reads or increments this anymore. Kept in the
  // schema so `prisma db push` (the flag-less release_command) doesn't try
  // to DROP it — a destructive change that aborts the deploy. Remove via a
  // deliberate, flagged migration if/when quota stays gone for good.
  signup_count      Int       @default(0)
  last_used_at      DateTime?
  // The account this token is bound to. The PWA's
  // /v1/mcp/pair/:token/claim sets this.
  paired_account_id String?   @db.VarChar(26)

  // Install-time network classification. We don't refresh this over
  // time — if a user moves networks, future captcha events will tell
  // a different story than the install-time class, which is itself
  // useful signal.
  asn_class   String? // "residential" | "datacenter" | "unknown"
  asn_number  String? // e.g. "AS24940"
  asn_org     String? // e.g. "Hetzner Online GmbH"
  asn_country String? // ISO 2-letter

  @@index([paired_account_id])
  @@index([asn_class])
}

// Captcha-failure ledger. One row per detected captcha block during a
// signup attempt. Lets us answer "what % of failures come from
// datacenter networks?" with data — the leading indicator for whether
// residential-proxy work (Tier S1) is actually worth doing.
//
// Retention: short. These are operational telemetry, not user data.
model CaptchaEvent {
  id                 String   @id @default(cuid())
  occurred_at        DateTime @default(now())
  machine_token      String?
  service            String
  // "turnstile" | "recaptcha" | "unknown"
  captcha_kind       String
  // Same shape as MachineToken.asn_class. Captured at event time, not
  // looked up retroactively — the machine might have moved networks
  // since install.
  asn_class          String?
  asn_org            String?
  // Did the bot escape the captcha or was the run abandoned?
  blocked            Boolean
  // Whether the bot's browser egress was routed through the
  // residential proxy on this run. null = pre-0.1.8 client that
  // didn't report it (distinct from false = ran direct). This is the
  // field that makes "did the proxy help?" answerable from data.
  proxied            Boolean?
  // Spike telemetry (T3.2) — null on all three = pre-0.1.9 client.
  // captcha_variant: which captcha family the bot faced
  // ("recaptcha_v2" | "recaptcha_v3" | "turnstile" | "hcaptcha" |
  // "unknown"). challenge_rendered: did a solvable image-grid
  // challenge actually render (vs a checkbox that passed, or
  // score-only reCAPTCHA). signup_succeeded: the run's ultimate
  // outcome — the number that says whether clearing a captcha
  // actually leads to a completed signup.
  captcha_variant    String?
  challenge_rendered Boolean?
  signup_succeeded   Boolean?
  // Which stealth launcher ran: "baseline" (vanilla playwright) or
  // "cdp_hardened" (rebrowser-playwright-core, Runtime.enable leak
  // closed). null = pre-CDP-hardening client. The A/B tag for measuring
  // whether the patch lowers block rate — docs/ARCHITECTURE.md.
  stealth_profile    String?

  @@index([occurred_at])
  @@index([asn_class, blocked])
  @@index([service, blocked])
  @@index([proxied, blocked])
  @@index([captcha_variant, signup_succeeded])
  @@index([stealth_profile, blocked])
}

// MCP pair-flow tokens. 10-minute TTL; single-use claim. Expiry is
// enforced in code, not DB — a background cron can sweep expired rows.
model PairingToken {
  token                      String   @id
  created_at                 DateTime @default(now())
  expires_at                 DateTime
  status                     String // "pending" | "claimed" | "expired" | "delivered"
  agent_identity             String?
  agent_session_raw_token    String?
  account_id                 String?  @db.VarChar(26)
  // Tier 0 → Tier 1 upgrade hook. When the CLI declared its machine
  // token at /initiate, the eventual /claim marks the machine token
  // paired so the quota counter stops.
  machine_token              String?
  // Browser-side install choices returned to the CLI on first status poll.
  registry_enabled           Boolean?
  consent_operator_inbox_otp Boolean?
  proxy_url                  String?

  @@index([machine_token])
  @@index([status, expires_at])
}

// ── Tier 1 account layer ─────────────────────────────────────
// Paired accounts and their auth/session state. Until now these
// lived only in restart-volatile in-memory stores; persisting them
// is what makes OAuth login, CLI pairing, and the vault durable
// across deploys.

// One paired account. `id` is a ULID.
model Account {
  id            String   @id @db.VarChar(26)
  email         String   @unique
  display_name  String
  default_vault String?
  created_at    DateTime @default(now())

  // Stripe billing. `subscription_status` is what the free-signup quota
  // gate consults — "active" bypasses the quota; anything else (the
  // "free" default, "past_due", "canceled") leaves the quota in force.
  // The Stripe webhook is the only writer; the customer/subscription ids
  // are stored so the portal + subsequent webhook events can map back.
  //
  // NOT @unique on purpose: `prisma db push` (our flag-less release_command)
  // refuses to add a unique constraint without --accept-data-loss — on every
  // DB, fresh or not, since the check is static. The deploy is meant to abort
  // on destructive migrations, so a unique constraint can never go through it.
  // Uniqueness holds by construction instead (the webhook is the only writer,
  // one Stripe customer per account); the index backs the customer→account
  // lookup. Add the DB constraint later via a deliberate, flagged migration.
  stripe_customer_id  String?
  subscription_status String    @default("free")
  subscription_id     String?
  current_period_end  DateTime?
  // Set when the subscription is scheduled to end (cancel-at-period-end).
  // null = not scheduled to cancel. Lets the UI show "active — cancels <date>"
  // so a cancellation is visibly registered while access continues to term.
  cancel_at           DateTime?

  // Telegram chat the account linked via /v1/telegram/link + the bot's
  // /start deep link. null = not linked; payment-approval push is skipped.
  telegram_chat_id String? @map("telegram_chat_id")

  oauth_identities     OAuthIdentity[]
  web_sessions         WebSession[]
  agent_sessions       AgentSession[]
  e2e_credentials      E2ECredential[]
  payment_audit_events PaymentAuditEvent[]
  payment_approvals    PendingPaymentApproval[]
  telegram_link_tokens TelegramLinkToken[]

  @@index([stripe_customer_id])
}

// A linked OAuth provider identity. The (provider, provider_user_id)
// pair is the stable external identifier we match logins against.
model OAuthIdentity {
  id               String   @id @db.VarChar(26)
  account_id       String   @db.VarChar(26)
  provider         String // "google" | "github"
  provider_user_id String
  email            String
  created_at       DateTime @default(now())

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_user_id])
  @@index([account_id])
}

// Web sessions — JWT in an HTTP-only cookie. `jwt_id` is looked up on
// every authed request so revocation works without changing the
// cookie format.
model WebSession {
  id                  String    @id @db.VarChar(26)
  account_id          String    @db.VarChar(26)
  jwt_id              String    @unique
  issued_at           DateTime  @default(now())
  last_active_at      DateTime
  absolute_expires_at DateTime
  revoked_at          DateTime?
  revocation_reason   String?
  ip                  String?
  user_agent          String?

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id])
}

// Agent (MCP/CLI) sessions — the bearer token a paired CLI carries.
// Only SHA-256(token) is stored. This is the table the "connected
// agents" view lists and revokes.
model AgentSession {
  id                String    @id @db.VarChar(26)
  account_id        String    @db.VarChar(26)
  token_hash        String    @unique
  agent_identity    String?
  agent_version     String?
  issued_at         DateTime  @default(now())
  expires_at        DateTime
  last_used_at      DateTime?
  use_count         Int       @default(0)
  revoked_at        DateTime?
  revocation_reason String?
  account           Account   @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id])
}

// Encrypted SaaS credentials the squire collects — the "vault". The
// AES-256-GCM envelope encryption is done by @trusty-squire/vault's
// CredentialVault; this table is just the at-rest store. account_id is
// indexed, not a foreign key — the vault is conceptually its own
// service with an independent lifecycle.
model Credential {
  id                 String    @id @db.VarChar(26)
  reference          String    @unique
  account_id         String    @db.VarChar(26)
  subscription_id    String
  type               String?
  env_var_suggestion String?
  // One entry per (account, service, label); label defaults "default".
  label              String    @default("default")
  // Plaintext names of the secret fields (NOT secret). ciphertext
  // encrypts a JSON object { [field]: value }. A lone key is ["value"].
  field_names        String[]  @default([])
  // ENFORCED host allowlist for the use_credential proxy — off-allowlist
  // is hard-rejected. Seeded from service name; user-editable in /vault.
  allowed_hosts      String[]  @default([])
  ciphertext         Bytes
  encrypted_dek      Bytes
  account_kek_blob   Bytes
  algorithm          String    @default("AES-256-GCM")
  metadata           Json      @default("{}")
  rotated_at         DateTime?
  retrieval_count    Int       @default(0)
  last_retrieved_at  DateTime?
  deleted_at         DateTime?
  created_at         DateTime  @default(now())

  @@index([account_id])
  @@index([subscription_id])
}

// Vault audit log. One row per vault state-change or retrieval attempt.
// Used both for the in-vault rate limiter (counts recent retrievals)
// and for the user-facing "who touched my credentials" timeline. The
// payload is a free-form JSON object whose shape depends on `type`
// (see VaultAuditPayload in packages/vault/src/types.ts).
//
// Retention: indefinite for v0 — this is the user's own forensic
// trail. Add a sweep later if the table grows past a few million
// rows per account.
model VaultAuditEvent {
  id         String   @id @db.VarChar(26)
  account_id String   @db.VarChar(26)
  type       String
  payload    Json
  emitted_at DateTime @default(now())

  @@index([account_id, emitted_at])
  @@index([type, emitted_at])
  @@index([account_id, type, emitted_at])
}

// Opaque client-encrypted credential blobs. The API stores the blob
// verbatim and cannot decrypt or inspect it.
model E2ECredential {
  id         String   @id @db.VarChar(26)
  account_id String   @db.VarChar(26)
  label      String
  blob       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id])
}

// Non-secret record of a card payment attempt. PAN/CVV are never stored.
model PaymentAuditEvent {
  id           String   @id @db.VarChar(26)
  account_id   String   @db.VarChar(26)
  merchant     String
  amount_cents Int
  currency     String
  last4        String
  status       String
  mandate_id   String?
  created_at   DateTime @default(now())

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id])
}

// Ephemeral relay for opaque payment approval payloads.
model PendingPaymentApproval {
  id              String   @id @db.VarChar(26)
  account_id      String   @db.VarChar(26)
  merchant        String
  checkout_origin String
  amount_cents    Int
  currency        String
  nonce           String
  card_ref        String
  operator_pubkey String
  item            String   @default("")
  reason          String   @default("")
  agent           String   @default("")
  status          String
  jws             String?
  sealed_card     String?
  created_at      DateTime @default(now())
  expires_at      DateTime

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id])
  @@map("pending_payment_approvals")
}

// Telegram account-linking token. Minted by POST /v1/telegram/link,
// consumed by the webhook when the user taps the bot's /start deep link.
// 15-minute TTL, single-use. Mirrors PairingToken's shape.
model TelegramLinkToken {
  token      String   @id
  account_id String   @db.VarChar(26)
  created_at DateTime @default(now())
  expires_at DateTime

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id])
}

// Egress grant — a standing, revocable token a deployed workload holds to
// call a provider through the injecting proxy, so the raw vault credential
// never leaves the server (v1a of Egress Grants; see docs/ARCHITECTURE.md).
// id is `g_<hex>` (not a ULID), so no VarChar(26). Only the token HASH is
// stored — the token itself is shown to the caller exactly once at mint.
model EgressGrant {
  id                  String    @id
  account_id          String    @db.VarChar(26)
  credential_ref      String
  token_hash          String    @unique
  rate_limit_per_hour Int
  spend_cap_usd       Float?
  created_at          DateTime  @default(now())
  revoked_at          DateTime?

  @@index([account_id])
  @@index([token_hash])
}
