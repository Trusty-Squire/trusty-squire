{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus on Fly",
      "description": "The Fly-managed Prometheus that scrapes the app (infra metrics) and the private squire_* exporter (funnel + health).",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "title": "Trusty Squire — Launch",
  "uid": "ts-launch",
  "tags": ["trusty-squire", "launch"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "links": [
    { "title": "Fly App (infra)", "type": "link", "icon": "external link", "url": "/d/fly-app/fly-app", "targetBlank": true },
    { "title": "Fly Edge", "type": "link", "icon": "external link", "url": "/d/fly-edge/fly-edge", "targetBlank": true },
    { "title": "Sentry (error triage)", "type": "link", "icon": "external link", "url": "https://methoxine.sentry.io", "targetBlank": true }
  ],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🚨 Health & errors — is it on fire?",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Database",
      "description": "squire_db_up — 1 if the DB answered the liveness probe. The 256MB OOM-wedge failure mode shows here as DOWN.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "refId": "A", "expr": "max(squire_db_up)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "5xx error rate (req/s)",
      "description": "Server errors from Fly's edge HTTP metrics. The dead-center 'is it on fire?' signal — when this climbs, click into Sentry for the stack trace.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 1 },
      "targets": [{ "refId": "A", "expr": "sum(rate(fly_edge_http_responses_count{app=\"trusty-squire-api\", status=~\"5..\"}[$__rate_interval]))", "legendFormat": "5xx", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 30, "gradientMode": "opacity", "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.1 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "showLegend": false, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP responses by status (req/s)",
      "description": "Total request rate split by status class — the overall traffic + health picture from Fly's edge.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 1 },
      "targets": [{ "refId": "A", "expr": "sum by (status) (rate(fly_edge_http_responses_count{app=\"trusty-squire-api\"}[$__rate_interval]))", "legendFormat": "{{status}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10,
      "type": "row",
      "title": "📈 Funnel — adoption",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Accounts",
      "description": "squire_accounts_total",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 10 },
      "targets": [{ "refId": "A", "expr": "max(squire_accounts_total)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Residential installs",
      "description": "squire_residential_installs_total — machine tokens from residential ASNs. The honest external-adoption signal (excludes infra/CI tokens).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 10 },
      "targets": [{ "refId": "A", "expr": "max(squire_residential_installs_total)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Machine tokens (all)",
      "description": "squire_machine_tokens_total — includes infra/CI/dev tokens; residential installs is the cleaner adoption number.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 10 },
      "targets": [{ "refId": "A", "expr": "max(squire_machine_tokens_total)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Vault credentials",
      "description": "squire_credentials_total — credentials stored in the vault.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 10 },
      "targets": [{ "refId": "A", "expr": "max(squire_credentials_total)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Active egress grants",
      "description": "squire_egress_grants_active — standing workload tokens not yet revoked.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 10 },
      "targets": [{ "refId": "A", "expr": "max(squire_egress_grants_active)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Adoption over time",
      "description": "Accounts, residential installs and total machine tokens as Prometheus tracks them across scrapes.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "refId": "A", "expr": "max(squire_accounts_total)", "legendFormat": "accounts", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "B", "expr": "max(squire_residential_installs_total)", "legendFormat": "residential installs", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "C", "expr": "max(squire_machine_tokens_total)", "legendFormat": "machine tokens", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Vault & egress activity",
      "description": "Credentials, audit-trail events and active grants over time — the 'is the vault being used' picture.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "refId": "A", "expr": "max(squire_credentials_total)", "legendFormat": "credentials", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "B", "expr": "max(squire_vault_audit_events_total)", "legendFormat": "audit events", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "C", "expr": "max(squire_egress_grants_active)", "legendFormat": "active grants", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "D", "expr": "max(squire_captcha_events_total)", "legendFormat": "captcha events", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
