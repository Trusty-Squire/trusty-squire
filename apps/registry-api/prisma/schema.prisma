// Registry persistence schema. Lives in trusty_squire_registry —
// adapter manifests are public read-only data with their own
// retention story (we keep all versions forever; disabled flips
// flip the kill-switch but don't delete).

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/registry-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("REGISTRY_DATABASE_URL")
}

model AdapterManifestRecord {
  service          String
  version          String
  // Full manifest JSON exactly as published — this is the bytes
  // the runtime reads to drive a flow. Any change here would
  // change the canonical-bytes-derived signature.
  manifest_json    Json
  signature        String
  signed_at        DateTime
  signed_by        String

  // Kill-switch + reason. Disabled versions return 410 Gone;
  // older non-disabled versions of the same service still serve
  // (operators can pin to a known-good prior).
  disabled_at      DateTime?
  disabled_reason  String?

  created_at       DateTime  @default(now())

  @@id([service, version])
  @@index([service])
  @@index([disabled_at])
}

// SkillRecord — Tier-2 Learned Skills (0.7.0).
//
// Lives in the same database as AdapterManifestRecord but in a
// separate table. The user-visible "unified" routing experience
// (Decision 2 → option A) is delivered at the route layer, which
// resolves "what runs this service?" against both tables and returns
// whichever tier has an active record. Two storage tables + one router
// lookup gives us the unified UX without forcing Prisma migrations on
// the existing immutable AdapterManifestRecord every time the skill
// schema iterates.
//
// `payload_json` carries the full SkillSchema-validated JSON. Health
// counters live as columns rather than inside the JSON so atomic SQL
// UPDATE works (E3 race-condition fix).
model SkillRecord {
  // ULID-shaped skill identifier. Primary key because (service,
  // version) isn't unique — skill:edit can republish the same
  // version with new content under a fresh skill_id.
  skill_id             String   @id

  // Identity + routing
  service              String
  version              String

  // Signed payload + signature. Same signer infrastructure as
  // AdapterManifestRecord; signature attests to the payload bytes.
  payload_json         Json
  signature            String
  signed_at            DateTime
  signed_by            String

  // Lifecycle status. Mirrors SkillStatus in @trusty-squire/adapter-sdk.
  // Stored as TEXT (not Prisma enum) so adding new variants doesn't
  // require a migration — the schema-package Zod enum is the source
  // of truth.
  status               String

  // Health counters. Updated via atomic SQL on each replay outcome.
  replays_succeeded    Int      @default(0)
  replays_failed       Int      @default(0)
  consecutive_failures Int      @default(0)

  // Verifier-worker counters (closed-loop staging gate). Tracked
  // separately from end-user replays so a freshness-sweep failure
  // doesn't contaminate the user-facing replay-success-rate stats,
  // and so the promotion gate has authoritative numbers to read.
  //   pending-review → bumped on every verifier run, promotes to
  //   active once verifier_succeeded reaches the threshold (N=2)
  //   without an interleaving failure. consecutive_verifier_failures
  //   resets on success; reaching 3 in a row retires the skill.
  verifier_succeeded            Int       @default(0)
  verifier_failed               Int       @default(0)
  consecutive_verifier_failures Int       @default(0)
  last_verified_at              DateTime?
  // When the freshness sweep should re-test this skill. NULL =
  // never (pending-review skills get a value once they hit active).
  next_freshness_due_at         DateTime?
  // Per-skill monthly verifier spend ceiling, in cents. Defaults to
  // $1/skill/month. When the verifier worker exceeds this it stops
  // re-testing and the skill is auto-retired with reason="budget".
  freshness_budget_cents        Int       @default(100)

  // Timestamps
  created_at           DateTime @default(now())
  last_replayed_at     DateTime?
  superseded_at        DateTime?
  deleted_at           DateTime?

  // Reverse relation to replay outcomes for trail debugging.
  replays              SkillReplayRecord[]

  // Hot-path index: router asks "what's the active skill for this
  // service?". Indexed for that exact query shape.
  @@index([service, status])
  @@index([service])
  @@index([status])
  @@index([deleted_at])
  // Freshness sweep: verifier worker selects skills whose freshness
  // window has elapsed in due-date order.
  @@index([next_freshness_due_at])
}

// SkillReplayRecord — one row per replay outcome reported by the
// router. Powers GET /skills/:service/replays (D7) and feeds the
// auto-demotion logic in POST /skills/:id/replay-outcome.
model SkillReplayRecord {
  id          String      @id @default(cuid())
  skill_id    String
  skill       SkillRecord @relation(fields: [skill_id], references: [skill_id], onDelete: Cascade)

  // The ReplayOutcome.kind serialised as TEXT.
  outcome     String

  // Free-text reason from the router. Bounded to 2000 chars at the
  // API layer to keep the table small under load.
  reason      String

  // Which account ran the replay. Powers per-account rate limiting
  // and account-scoped debugging.
  account_id  String

  // Which step (if any) failed. NULL for outcome="ok" or "dry_pass".
  step_index  Int?

  // When the replay happened.
  replayed_at DateTime @default(now())

  @@index([skill_id])
  @@index([skill_id, replayed_at])
  @@index([account_id, replayed_at])
}

// SkillCaptureRecord — content-hashed corpus sidecars (T19, D1). When
// a skill is promoted from a universal-bot run, the raw onboarding-
// capture JSONL files that produced it get uploaded here as evidence.
// Content-hashed so re-uploads are idempotent and the same capture
// referenced by multiple skills only takes one row of storage.
//
// The replay engine + operator console resolve `Skill.source_run_ids`
// to the actual capture files via this table — without it, source_run_ids
// would point to local-laptop dirs that won't exist months later.
model SkillCaptureRecord {
  // SHA-256 of the capture content, hex-lowercased. Primary key —
  // identical content always produces the same row.
  content_hash String   @id

  // Which skill this capture contributed to. NOT a foreign key (a
  // capture can outlive its skill, especially after deletion), but
  // indexed for the "show me all captures for skill X" query.
  skill_id     String

  // The run_id from the universal-bot run. Matches one of the
  // entries in Skill.source_run_ids. Indexed so a single skill's
  // captures can be assembled.
  run_id       String

  // Which round in the capture chain. 0-indexed.
  round_index  Int

  // The raw capture JSON. Stored verbatim — the chain's prev_hash
  // links resolve against this row's content_hash.
  payload_json Json

  // Bytes. Useful for storage budgeting and rate limiting uploads
  // by total volume per account.
  byte_size    Int

  // When the upload happened.
  uploaded_at  DateTime @default(now())

  // Who uploaded — the account_id from x-account-id header on the
  // POST /skills/:skill_id/captures call. Used for audit + rate
  // limiting future uploads from the same account.
  uploaded_by  String

  @@index([skill_id])
  @@index([skill_id, round_index])
  @@index([run_id])
}

// UniversalBotFailureRecord — closed-loop strategy Phase 5.
//
// Posted by end-user MCPs whenever a universal-bot signup
// terminally fails for a service. Drives the discovery worker
// (Phase 6): services with ≥3 distinct user failures in the last
// 14 days, where the registry has no active skill, become
// discovery candidates the worker iterates against.
//
// Trust model: anyone with a machine token can post — these are
// telemetry events, not authoritative facts. The registry trusts
// reported_at via the server clock, not the client. Per-account
// rate limiting (later) prevents one user spamming a service.
//
// Retention: 90 days (longer than the 14-day aggregation window
// so we can backfill if the discovery worker adjusts the lookback).
model UniversalBotFailureRecord {
  id           String   @id @default(cuid())
  // Slug the bot was trying to provision — exactly the form the
  // discovery worker would re-attempt. Lowercased + slug-normalized
  // before insert.
  service      String
  // Bot's terminal-failure classification: no_credentials,
  // oauth_onboarding_failed, verification_not_sent,
  // anti_bot_blocked, onboarding_blocked, captcha_blocked, etc.
  error_kind   String
  // Free-text reason from the bot (capped server-side to 2KB).
  reason       String
  // Whoever's machine token / account ran the signup. Used for
  // (a) per-account rate limiting and (b) the "≥3 DISTINCT users"
  // aggregation gate.
  account_id   String
  // Which MCP version produced the report. Helps triage "this
  // class of failure went away after rc.39".
  mcp_version  String
  reported_at  DateTime @default(now())

  // Aggregation is per (service, reported_at window). Indexed for
  // that scan + the per-account rate-limit lookup.
  @@index([service, reported_at(sort: Desc)])
  @@index([account_id, reported_at(sort: Desc)])
  @@index([reported_at])
}

// ExtractFailureSnapshot — DOM + screenshot from a universal-bot run
// where extractCredentials() returned null. Auto-uploaded by the MCP
// so DOM-shape regressions can be diagnosed without users needing to
// configure debug env vars. 7-day retention via daily pruner.
model ExtractFailureSnapshot {
  // nanoid; primary key
  id               String   @id

  // Owner account_id from x-account-id on the upload. Scopes every
  // read to "snapshots my account uploaded".
  account_id       String

  // Which service the bot was provisioning ("Railway", "Postmark", …).
  service          String

  // Which MCP version produced the snapshot. Lets us correlate "this
  // shape broke in 0.6.14-rc.7 but extracts fine in 0.6.14-rc.9".
  mcp_version      String

  uploaded_at      DateTime @default(now())

  // now() + 7 days. The pruner deletes WHERE expires_at < now().
  expires_at       DateTime

  // Page context at the moment of the failed extract.
  url              String
  title            String

  // Human-readable label of which step in the planner loop failed
  // (e.g. "post-verify round 12: extract").
  step_label       String

  // The LLM's prose reason for issuing the extract step — usually
  // contains the literal token the LLM saw in the screenshot.
  extract_reason   String

  // What extractCredentialCandidates() / extractAllInputValues()
  // returned. JSONB so we can query "did Pass 3 see anything?"
  // without re-parsing the HTML.
  candidates_json  Json?

  // Gzipped innerHTML at the time of failure.
  html_gzip        Bytes

  // JPEG screenshot the planner saw (the same bytes that went to
  // Claude). Optional — older MCPs and feature-gated uploads may omit.
  screenshot_jpeg  Bytes?

  // Raw byte sizes (pre-compression for HTML, raw for JPEG). Useful
  // for storage budgeting + alerts.
  html_bytes       Int
  screenshot_bytes Int      @default(0)

  @@index([account_id, uploaded_at(sort: Desc)])
  @@index([expires_at])
  @@index([service])
}
