# Local development environment
DATABASE_URL=postgresql://dev:dev@localhost:5432/trusty_squire
VAULT_DATABASE_URL=postgresql://dev:dev@localhost:5432/trusty_squire_vault
INBOX_DATABASE_URL=postgresql://dev:dev@localhost:5432/trusty_squire_inbox
REGISTRY_DATABASE_URL=postgresql://dev:dev@localhost:5432/trusty_squire_registry
REDIS_URL=redis://localhost:6379
NODE_ENV=development
LOG_LEVEL=debug

# Vault — local dev master key (NEVER use in production).
# 32-byte key encoded as 64 hex chars. Generate one for local with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOCAL_KMS_KEY=

# Adapter signing — Ed25519 keypair, both encoded as base64url.
# Generate with:
#   node -e "const c=require('crypto');const{privateKey,publicKey}=c.generateKeyPairSync('ed25519');console.log('private:',privateKey.export({format:'der',type:'pkcs8'}).toString('base64url'));console.log('public:',publicKey.export({format:'der',type:'spki'}).toString('base64url'));"
ADAPTER_SIGNING_PRIVATE_KEY=
ADAPTER_SIGNING_PUBLIC_KEY=

# Registry API (apps/registry)
REGISTRY_API_PORT=3001
# Where the runtime + Resend adapter look up manifests in dev.
ADAPTER_REGISTRY_URL=http://localhost:3001

# Main API (apps/api)
API_PORT=3000
# HS256 secret for session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_JWT_SECRET=
# Vouchflow-issued customer id used as the JWS `aud` claim.
VOUCHFLOW_CUSTOMER_ID=
