{
  "name": "@trusty-squire/skill-schema",
  "version": "0.1.0-rc.1",
  "type": "module",
  "description": "Type-checked learned-skill schema for Trusty Squire. Defines the wire contract every registry-stored skill is validated against, shared by the mcp client and the registry server.",
  "license": "MIT",
  "author": "Trusty Squire",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trusty-Squire/trusty-squire.git",
    "directory": "packages/skill-schema"
  },
  "homepage": "https://github.com/Trusty-Squire/trusty-squire/tree/main/packages/skill-schema#readme",
  "bugs": {
    "url": "https://github.com/Trusty-Squire/trusty-squire/issues"
  },
  "keywords": [
    "trusty-squire",
    "skill",
    "schema",
    "zod"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "rm -rf dist && npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
