{
  "name": "@trusty-squire/mandate-validator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mandate signature verification + policy evaluation for Trusty Squire.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
