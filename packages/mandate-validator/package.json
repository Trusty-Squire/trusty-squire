    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "canonicalize": "^2.0.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
