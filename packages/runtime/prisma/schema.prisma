// Trusty Squire — runtime persistence schema.
//
// All IDs are ULIDs stored as VarChar(26). Timestamps are DateTime
// (UTC). Json columns hold structured data the state machine treats
// as opaque (steps, side_effects, context, credentials, payload).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Identity ─────────────────────────────────────────────────

model Account {
  id            String   @id @db.VarChar(26)
  email         String   @unique
  display_name  String
  // Reference into the vault config table (built in chunk 6); kept
  // as a string id here so this model does not block on vault models.
  default_vault String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  members        Member[]
  devices        Device[]
  mandates       Mandate[]
  subscriptions  Subscription[]
  runs           Run[]
  run_events     RunEvent[]
  email_aliases  EmailAlias[]
  sessions       Session[]
  agent_sessions AgentSession[]
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model Member {
  id           String     @id @db.VarChar(26)
  account_id   String     @db.VarChar(26)
  email        String
  display_name String?
  role         MemberRole

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@unique([account_id, email])
  @@index([account_id])
}

enum DevicePlatform {
  ios
  android
  web
}

model Device {
  id                       String         @id @db.VarChar(26)
  account_id               String         @db.VarChar(26)
  platform                 DevicePlatform
  // Mobile (Vouchflow) devices store the opaque token; desktop
  // (WebAuthn) devices store the credential id. One of the two will
  // be populated per device.
  vouchflow_token          String?
  webauthn_credential_id   String?
  attestation_chain        Json?
  public_key               String
  display_name             String?
  registered_at            DateTime       @default(now())
  last_seen_at             DateTime?
  revoked_at               DateTime?

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@unique([account_id, webauthn_credential_id])
  @@unique([account_id, vouchflow_token])
  @@index([account_id])
}

// ── Mandates ─────────────────────────────────────────────────

model Mandate {
  id         String @id @db.VarChar(26)
  account_id String @db.VarChar(26)

  // Policy fields — kept structured (not a single Json blob) so the
  // policy evaluator can query / sum without parsing.
  monthly_budget_cents          Int
  daily_silent_max_cents        Int
  per_action_silent_max_cents   Int
  per_subscription_max_cents    Int
  allowed_categories            String[]
  // "*" sentinel allowed; stored verbatim.
  allowed_services              String[]
  blocked_services              String[]
  // Loose Json for evolving policy sub-shapes (step-up triggers, silent
  // approvals, confidence requirements). Fully validated by the
  // mandate-validator package on read.
  step_up_triggers              Json
  silently_approved_services    Json
  confidence_requirements       Json
  signing_devices               Json

  // Validity window
  not_before DateTime
  not_after  DateTime

  // Lifecycle
  signature        String
  signed_at        DateTime
  signing_device_id String   @db.VarChar(26)
  superseded_by    String?  @db.VarChar(26)
  revoked_at       DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)
  runs    Run[]

  @@index([account_id, not_after])
}

// ── Subscriptions (the result of a successful run) ───────────

enum SubscriptionStatus {
  active
  cancelled
  paused
  failed
}

model Subscription {
  id              String             @id @db.VarChar(26)
  account_id      String             @db.VarChar(26)
  service         String
  plan            String
  status          SubscriptionStatus
  monthly_cents   Int
  adapter_version String
  metadata        Json
  // Lifecycle
  opened_at    DateTime  @default(now())
  cancelled_at DateTime?
  next_renewal DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)
  runs    Run[]

  @@index([account_id, service])
  @@index([account_id, status])
}

// ── Runs ─────────────────────────────────────────────────────

enum RunState {
  CREATED
  MANDATE_VALIDATED
  PENDING_APPROVAL
  PROVISIONING
  ADAPTER_EXECUTING
  CRED_EXTRACTED
  VAULT_WRITTEN
  TIER_ESCALATING
  COMPENSATING
  COMPLETE
  FAILED
  REJECTED
}

model Run {
  id                  String   @id @db.VarChar(26)
  account_id          String   @db.VarChar(26)
  idempotency_key     String
  service             String
  plan                String
  project_name        String
  user_facing_purpose String?

  state            RunState
  state_entered_at DateTime
  retry_count      Int      @default(0)

  mandate_id       String  @db.VarChar(26)
  delta_mandate_id String? @db.VarChar(26)

  adapter_id      String
  adapter_version String
  current_tier    Int     @default(1)

  // Json columns — the state machine treats these as opaque structures.
  // Schema lives in @trusty-squire/runtime/src/types.ts.
  steps        Json
  side_effects Json
  context      Json
  credentials  Json?

  subscription_id String? @db.VarChar(26)

  failure_reason String?
  failure_detail Json?

  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  completed_at DateTime?

  account          Account         @relation(fields: [account_id], references: [id], onDelete: Cascade)
  mandate          Mandate         @relation(fields: [mandate_id], references: [id])
  subscription     Subscription?   @relation(fields: [subscription_id], references: [id])
  events           RunEvent[]
  approval_tokens  ApprovalToken[]

  @@unique([account_id, idempotency_key])
  @@index([state, state_entered_at])
  @@index([account_id, created_at])
}

// ── Audit (the ledger) ───────────────────────────────────────

model RunEvent {
  id         String   @id @db.VarChar(26)
  run_id     String   @db.VarChar(26)
  account_id String   @db.VarChar(26)
  type       String
  from_state RunState
  to_state   RunState
  payload    Json
  emitted_at DateTime @default(now())

  run     Run     @relation(fields: [run_id], references: [id], onDelete: Cascade)
  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([run_id, emitted_at])
  @@index([account_id, emitted_at])
}

// ── Email aliases (per-run inbox bindings) ───────────────────

model EmailAlias {
  id         String   @id @db.VarChar(26)
  alias      String   @unique
  account_id String   @db.VarChar(26)
  run_id     String?  @db.VarChar(26)
  service    String
  active     Boolean  @default(true)
  expires_at DateTime?

  created_at DateTime @default(now())

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id, service])
  @@index([active, expires_at])
}

// ── Anti-replay (mandate / delta nonce tracking) ─────────────

model UsedNonce {
  nonce      String   @id
  account_id String   @db.VarChar(26)
  // Free-form: callers stamp 'mandate' or 'delta' as appropriate.
  context    String
  used_at    DateTime @default(now())
  // Validator caller is responsible for pruning rows past this; the
  // mandate-validator package additionally rejects stale-signed_at
  // payloads as defense-in-depth.
  expires_at DateTime

  @@index([expires_at])
  @@index([account_id, used_at])
}

// ────────────────────────────────────────────────────────────────────
// AUTH — chunk 10 additions
// ────────────────────────────────────────────────────────────────────
//
// Web sessions are revocable JWTs: we issue a cookie with the JWT, but
// the JWT's jti is looked up here on every authenticated request so
// we can revoke without invalidating cookie format. Web sessions have
// idle expiry (15min from last activity, refreshed on each authed
// request) plus an absolute expiry (8h hard cap) — driven by the
// auth middleware, not the DB layer.
//
// Agent sessions are bearer tokens for the MCP server. Only the
// SHA-256 hash of the token is stored — the raw token is shown once
// at MCP install time and never persisted server-side. Agent sessions
// are 24h absolute, no refresh.
//
// Approval tokens are single-use base64url(32 bytes) strings tied to
// a Run in PENDING_APPROVAL. 5min expiry. The user signs the delta
// via Vouchflow signPayload; on success the token is burned.

model Session {
  id                  String   @id @db.VarChar(26)
  account_id          String   @db.VarChar(26)

  // Matches the JWT `jti` claim. Looked up on every authenticated
  // request — `revoked_at` non-null or `absolute_expires_at` past
  // means the cookie's still parseable but no longer valid.
  jwt_id              String   @unique

  issued_at           DateTime @default(now())
  last_active_at      DateTime @default(now())
  absolute_expires_at DateTime

  revoked_at          DateTime?
  revocation_reason   String?

  ip                  String?
  user_agent          String?

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id, revoked_at])
  @@index([jwt_id])
}

model AgentSession {
  id                String   @id @db.VarChar(26)
  account_id        String   @db.VarChar(26)

  // SHA-256 hex of the bearer token. The raw token is shown to the
  // user once at issuance and never stored. A DB leak doesn't yield
  // usable agent sessions.
  token_hash        String   @unique

  // Self-reported by the MCP client at issue time. Used for the
  // ledger UI ("which coding agent acted on my behalf?"); not a
  // security control.
  agent_identity    String?
  agent_version    String?

  issued_at         DateTime @default(now())
  expires_at        DateTime

  last_used_at      DateTime?
  use_count         Int      @default(0)

  revoked_at        DateTime?
  revocation_reason String?

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id, revoked_at])
  @@index([token_hash])
}

model ApprovalToken {
  token       String   @id @db.VarChar(64)
  run_id      String   @db.VarChar(26)
  account_id  String   @db.VarChar(26)

  expires_at  DateTime
  used_at     DateTime?

  created_at  DateTime @default(now())

  run Run @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id])
  @@index([expires_at])
}
