// Vault persistence schema. Lives in its own database
// (trusty_squire_vault) so the credential blobs are isolated from the
// runtime DB blast radius.
//
// All blob columns store the AES-256-GCM concatenation
// `iv || ciphertext || tag` — no separate iv/tag columns. This keeps
// schema width down and makes it impossible to read one half without
// the other.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("VAULT_DATABASE_URL")
}

model Credential {
  id                  String    @id @db.VarChar(26)
  reference           String    @unique
  account_id          String    @db.VarChar(26)
  subscription_id     String    @db.VarChar(26)
  type                String
  env_var_suggestion  String?

  // value encrypted with the per-credential DEK; iv prepended,
  // GCM auth tag appended.
  ciphertext          Bytes
  // DEK encrypted with this credential's KEK; iv prepended,
  // GCM auth tag appended.
  encrypted_dek       Bytes
  // KEK encrypted by the master KMS key (LocalKMS in dev, AWS KMS
  // in prod). The KMS implementation owns the framing of this blob.
  account_kek_blob    Bytes
  algorithm           String    @default("AES-256-GCM")

  metadata            Json      @default("{}")

  rotated_at          DateTime?
  retrieval_count     Int       @default(0)
  last_retrieved_at   DateTime?
  // Soft delete — preserves audit chain. Hard delete only on
  // user-initiated account closure.
  deleted_at          DateTime?

  created_at          DateTime  @default(now())

  @@index([account_id])
  @@index([subscription_id])
  @@index([deleted_at])
}

// Vault-specific audit. Separate from runtime's RunEvent because the
// vault is its own service with its own retention policy (indefinite
// for v0).
model VaultAuditEvent {
  id          String   @id @db.VarChar(26)
  account_id  String   @db.VarChar(26)
  type        String
  payload     Json
  emitted_at  DateTime @default(now())

  @@index([account_id, emitted_at])
  @@index([type, emitted_at])
}
