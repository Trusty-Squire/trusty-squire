{
  "name": "@trusty-squire/vault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HSM-backed credential vault: envelope encryption + per-credential KEK + audit log.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "prisma": "^5.22.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
